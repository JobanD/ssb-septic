---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Septic Services & Pricing – SSB Septic Kent & Seattle"
    description="Explore our comprehensive range of septic services including system installation, maintenance, and repair. Trust SSB Septic Services for efficient and sustainable solutions tailored to both residential and commercial needs in Seattle and Kent."
>
    <!-- Hero Section -->
    <section class="page-hero">
        <div class="hero-bg"></div>
        <div class="hero-container">
            <span class="hero-label">Transparent Pricing</span>
            <h1 class="hero-title">SSB Services & Pricing</h1>
            <p class="hero-subtitle">Reliable | Efficient | Affordable | Local</p>
        </div>
    </section>

    <!-- Main Pricing Section -->
    <section class="pricing-section">
        <div class="section-container">
            <!-- Featured Price Card -->
            <div class="featured-price">
                <div class="price-header">
                    <span class="price-label">Most Popular</span>
                    <h2 class="price-service">Septic Tank Cleaning</h2>
                </div>
                <div class="price-amount">
                    <span class="currency">$</span>
                    <span class="number">600</span>
                    <span class="suffix">.00 + Tax</span>
                </div>
                <p class="price-description">SSB provides comprehensive cleaning ensures a healthier home and environment, including:</p>
                <ul class="price-features">
                    <li>
                        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Complete pump out and disposal for up to 1000 gallons</span>
                    </li>
                    <li>
                        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Visual inspection of the tank and components</span>
                    </li>
                    <li>
                        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Maintenance and usage recommendations</span>
                    </li>
                    <li>
                        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span>Available for Emergencies 24/7</span>
                    </li>
                </ul>
                <a href="tel:+12068338777" class="price-cta">
                    <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                    <span>Schedule Now</span>
                </a>
            </div>

            <!-- Additional Services Grid -->
            <div class="services-header">
                <h3 class="services-title">Additional Services & Pricing</h3>
            </div>
            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    </div>
                    <h4 class="service-name">Emergency Services</h4>
                    <p class="service-desc">Quick response and support for emergency septic problems.</p>
                    <span class="service-price">Contact for Pricing</span>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
                        </svg>
                    </div>
                    <h4 class="service-name">Tank Locating</h4>
                    <p class="service-desc">Professional services to locate your septic tank accurately.</p>
                    <span class="service-price">Starting at $200</span>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                        </svg>
                    </div>
                    <h4 class="service-name">Dig Fees</h4>
                    <p class="service-desc">Charges for uncovering septic tank lids, typically required for tank inspection or cleaning.</p>
                    <span class="service-price">Starting at $200/lid</span>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                        </svg>
                    </div>
                    <h4 class="service-name">Cleaning & Pumping</h4>
                    <ul class="service-list">
                        <li>Pump/Holding Tank Cleaning: $0.57/gallon</li>
                        <li>Tanks up to 500 gal (lids exposed): $600 + tax</li>
                    </ul>
                </div>

                <div class="service-card service-card-wide">
                    <div class="service-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="3" width="15" height="13"/>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                            <circle cx="5.5" cy="18.5" r="2.5"/>
                            <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                    </div>
                    <div class="service-content">
                        <h4 class="service-name">Dump Trucking Services</h4>
                        <p class="service-desc">Professional hauling services for your project needs:</p>
                        <div class="service-tags">
                            <span class="tag">Gravel</span>
                            <span class="tag">Dirt</span>
                            <span class="tag">Asphalt</span>
                            <span class="tag">Bark</span>
                            <span class="tag">Topsoil</span>
                            <span class="tag">& More</span>
                        </div>
                    </div>
                    <a href="/contact" class="service-cta">Contact for More Info</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Section -->
    <section class="process-section">
        <div class="section-container">
            <div class="section-header">
                <span class="section-label">How It Works</span>
                <h2 class="section-title">Our Service Process</h2>
            </div>

            <div class="process-grid">
                <div class="process-card">
                    <div class="process-number">1</div>
                    <h3 class="process-title">Locating the Septic Tank & Lids</h3>
                    <ul class="process-list">
                        <li>Property owner's responsibility to know septic tank lid locations.</li>
                        <li>We assist with locating using county records included in the cost.</li>
                        <li>Electronic locator used if needed, costs $200.00.</li>
                    </ul>
                </div>

                <div class="process-card">
                    <div class="process-number">2</div>
                    <h3 class="process-title">Excavation of the Septic Tank's Lids</h3>
                    <ul class="process-list">
                        <li>Opportunity to save by uncovering lids prior to arrival.</li>
                        <li>Cost: $200.00 per lid.</li>
                        <li>Hourly labor rate reduced by 38% for digging.</li>
                    </ul>
                </div>

                <div class="process-card">
                    <div class="process-number">3</div>
                    <h3 class="process-title">Cleaning the Septic Tank</h3>
                    <ul class="process-list">
                        <li>Cleaning cost for a 1,000 gallon tank: $575.00 + tax.</li>
                        <li>Over 1,000 gallons: $0.57 per gallon + tax.</li>
                        <li>Additional costs for neglected septic systems.</li>
                        <li>Maintenance neglect may lead to costly repairs.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Terms Section -->
    <section class="terms-section">
        <div class="section-container">
            <div class="terms-card">
                <h3 class="terms-title">Terms & Conditions</h3>
                <div class="terms-content">
                    <p>Prices, terms, and conditions are subject to change.</p>
                    <p>SSB Septic reserves the right to deem a property's septic system unserviceable. Lids that are blocked by such things as buildings, concrete blockings, room additions, decks, trees, heavy brush or just plain junk will be deemed unserviceable.</p>
                    <p>SSB Septic reserves the right to refuse service for any reason.</p>
                    <p>For the safety of our community and employees, we do not operate on snow and ice days.</p>
                    <p>SSB Septic charges a $40 fee for any returned check or non-payment.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="section-container">
            <div class="cta-content">
                <h2 class="cta-title">Ready to Schedule Your Service?</h2>
                <p class="cta-text">Contact us now to get a quote and schedule your cleaning services.</p>
                <a href="tel:+12068338777" class="cta-button">
                    <svg viewBox="0 0 20 20" fill="currentColor">
                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                    </svg>
                    <span>Call Us Now</span>
                </a>
            </div>
        </div>
    </section>
</Layout>

<style>
/* Page Hero */
.page-hero {
    position: relative;
    padding: 8rem 1.25rem 5rem;
    text-align: center;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 50%, #1e3a5f 100%);
    z-index: -1;
}

.hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.hero-container {
    max-width: 48rem;
    margin: 0 auto;
}

.hero-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #86efc0;
    margin-bottom: 1rem;
}

.hero-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.1;
}

.hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    letter-spacing: 0.05em;
}

/* Section Container */
.section-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
}

.section-header {
    text-align: center;
    margin-bottom: 3rem;
}

.section-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2d8a6e;
    margin-bottom: 0.75rem;
}

.section-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0;
    line-height: 1.2;
}

/* Pricing Section */
.pricing-section {
    padding: 5rem 0;
    background: #f8fafc;
}

/* Featured Price Card */
.featured-price {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    border: 2px solid #2d8a6e;
    max-width: 32rem;
    margin: 0 auto 4rem;
    text-align: center;
}

.price-header {
    margin-bottom: 1.5rem;
}

.price-label {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: linear-gradient(135deg, #2d8a6e 0%, #3daa8e 100%);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 9999px;
    margin-bottom: 1rem;
}

.price-service {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0;
}

.price-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
}

.currency {
    font-size: 1.5rem;
    font-weight: 600;
    color: #2d8a6e;
}

.number {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 4rem;
    font-weight: 800;
    color: #2d8a6e;
    line-height: 1;
}

.suffix {
    font-size: 1rem;
    color: #64748b;
    font-weight: 500;
}

.price-description {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1.5rem;
    line-height: 1.6;
}

.price-features {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    text-align: left;
}

.price-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f1f5f9;
}

.price-features li:last-child {
    border-bottom: none;
}

.price-features svg {
    width: 1.25rem;
    height: 1.25rem;
    color: #2d8a6e;
    flex-shrink: 0;
    margin-top: 0.125rem;
}

.price-features span {
    font-size: 0.9375rem;
    color: #334155;
}

.price-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    color: white;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 12px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
}

.price-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(30, 58, 95, 0.4);
}

.price-cta svg {
    width: 1.25rem;
    height: 1.25rem;
}

/* Services Grid */
.services-header {
    text-align: center;
    margin-bottom: 2rem;
}

.services-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0;
}

.services-grid {
    display: grid;
    gap: 1.25rem;
}

.service-card {
    background: white;
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
}

.service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
}

.service-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 12px;
    margin-bottom: 1rem;
}

.service-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.service-name {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 0.5rem;
}

.service-desc {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1rem;
    line-height: 1.6;
}

.service-price {
    display: inline-block;
    font-size: 1rem;
    font-weight: 700;
    color: #2d8a6e;
}

.service-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.service-list li {
    font-size: 0.875rem;
    color: #64748b;
    padding: 0.375rem 0;
    border-bottom: 1px dashed #e2e8f0;
}

.service-list li:last-child {
    border-bottom: none;
}

.service-card-wide {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.service-content {
    flex: 1;
}

.service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
}

.tag {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: #f1f5f9;
    color: #475569;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 6px;
}

.service-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s ease;
}

.service-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
}

/* Process Section */
.process-section {
    padding: 5rem 0;
    background: white;
}

.process-grid {
    display: grid;
    gap: 1.5rem;
}

.process-card {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid #e2e8f0;
    position: relative;
}

.process-number {
    position: absolute;
    top: -0.75rem;
    left: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #2d8a6e 0%, #3daa8e 100%);
    color: white;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 50%;
    box-shadow: 0 4px 12px rgba(45, 138, 110, 0.3);
}

.process-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0.75rem 0 1rem;
}

.process-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.process-list li {
    font-size: 0.9375rem;
    color: #64748b;
    padding: 0.5rem 0;
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
}

.process-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.875rem;
    width: 6px;
    height: 6px;
    background: #2d8a6e;
    border-radius: 50%;
}

/* Terms Section */
.terms-section {
    padding: 4rem 0;
    background: #f8fafc;
}

.terms-card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
}

.terms-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 1.5rem;
}

.terms-content p {
    font-size: 0.9375rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0 0 1rem;
}

.terms-content p:last-child {
    margin-bottom: 0;
}

/* CTA Section */
.cta-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
}

.cta-content {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
}

.cta-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    color: white;
    margin: 0 0 1rem;
}

.cta-text {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 2rem;
    line-height: 1.6;
}

.cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: white;
    color: #1e3a5f;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 12px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}

.cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.25);
}

.cta-button svg {
    width: 1.25rem;
    height: 1.25rem;
}

/* Responsive */
@media (min-width: 640px) {
    .section-container {
        padding: 0 2rem;
    }

    .services-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .service-card-wide {
        grid-column: span 2;
        flex-direction: row;
        align-items: center;
    }

    .service-card-wide .service-icon {
        margin-bottom: 0;
    }

    .process-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (min-width: 768px) {
    .page-hero {
        padding: 10rem 2rem 6rem;
    }

