---
import Layout from '../layouts/Layout.astro';
import { Image } from "astro:assets";
import liveService from '../assets/live-service.jpg';
import truckBack from '../assets/back-truck.jpg';
---

<Layout
    title="Contact SSB Septic – Book Septic Service in Kent Today"
    description="Reach out to SSB Septic Services for professional and reliable septic system solutions. Contact us today for inquiries or to schedule a service in the Seattle and Kent area."
>
    <!-- Hero Section -->
    <section class="page-hero">
        <div class="hero-bg"></div>
        <div class="hero-container">
            <span class="hero-label">Get In Touch</span>
            <h1 class="hero-title">Contact SSB Septic Services</h1>
            <p class="hero-subtitle">Get in touch with Kent's trusted septic experts for all your septic system needs</p>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="contact-section">
        <div class="section-container">
            <!-- Contact Info Card -->
            <div class="info-card">
                <div class="info-header">
                    <h2 class="info-title">Get Your Free Quote Today</h2>
                    <p class="info-text">Professional septic services available 24/7 throughout the greater Seattle and Kent area. Our experienced team is ready to help with installations, maintenance, repairs, and emergency services.</p>
                </div>

                <div class="info-grid">
                    <div class="info-block">
                        <div class="info-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <h3 class="info-block-title">Business Hours</h3>
                        <div class="info-details">
                            <p><strong>Monday - Friday:</strong> 7:00 AM - 6:00 PM</p>
                            <p><strong>Saturday:</strong> 8:00 AM - 4:00 PM</p>
                            <p><strong>Sunday:</strong> Emergency Services Only</p>
                            <p class="highlight"><strong>Emergency Services:</strong> Available 24/7</p>
                        </div>
                    </div>

                    <div class="info-block">
                        <div class="info-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <h3 class="info-block-title">Contact Information</h3>
                        <div class="info-details">
                            <p><strong>Phone:</strong> <a href="tel:+12068338777" class="info-link">(206) 833-8777</a></p>
                            <p><strong>Address:</strong> 25000 180th Ave SE, Covington, WA 98042</p>
                            <p><strong>Service Areas:</strong> Kent, Seattle, Covington, Renton, Federal Way, Auburn, Snohomish County, and surrounding areas</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form Card -->
            <div class="form-card">
                <div class="form-header">
                    <h2 class="form-title">Request Service</h2>
                    <p class="form-text">Fill out this form and our team will follow up to schedule service.</p>
                </div>

                <form id="ssb-contact-form" name="ssb-contact-form" class="lead-form wc-track-form" action="/api/contact" method="post" novalidate>
                    <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
                    <input type="hidden" name="gclid" value="" />
                    <input type="hidden" name="gbraid" value="" />
                    <input type="hidden" name="wbraid" value="" />
                    <input type="hidden" name="utm_source" value="" />
                    <input type="hidden" name="utm_medium" value="" />
                    <input type="hidden" name="utm_campaign" value="" />
                    <input type="hidden" name="landing_page" value="" />
                    <input type="hidden" name="referrer" value="" />

                    <div class="form-grid form-grid-two">
                        <label class="form-field">
                            <span>First Name</span>
                            <input type="text" name="firstName" maxlength="50" required />
                        </label>
                        <label class="form-field">
                            <span>Last Name</span>
                            <input type="text" name="lastName" maxlength="50" required />
                        </label>
                    </div>

                    <div class="form-grid">
                        <label class="form-field">
                            <span>Street Address</span>
                            <input type="text" name="streetAddress" maxlength="120" required />
                        </label>
                    </div>

                    <div class="form-grid form-grid-two">
                        <label class="form-field">
                            <span>City</span>
                            <input type="text" name="city" maxlength="80" required />
                        </label>
                        <label class="form-field">
                            <span>ZIP</span>
                            <input type="text" name="zip" inputmode="numeric" maxlength="10" required />
                        </label>
                    </div>

                    <fieldset class="services-fieldset">
                        <legend>Services Needed</legend>
                        <div class="services-grid">
                            <label><input type="checkbox" name="services" value="Septic Pumping" /> Septic Pumping</label>
                            <label><input type="checkbox" name="services" value="Septic Inspection" /> Septic Inspection</label>
                            <label><input type="checkbox" name="services" value="Septic Repair" /> Septic Repair</label>
                            <label><input type="checkbox" name="services" value="Septic Installation" /> Septic Installation</label>
                            <label><input type="checkbox" name="services" value="Emergency Service" /> Emergency Service</label>
                            <label><input type="checkbox" name="services" value="Other" /> Other</label>
                        </div>
                    </fieldset>

                    <button id="ssb-contact-submit" type="submit" class="form-submit wc-track-submit">Send Request</button>
                    <p id="form-status" class="form-status" aria-live="polite"></p>
                </form>
            </div>

            <!-- Booking Section -->
            <div class="feature-card">
                <div class="feature-image">
                    <Image src={truckBack} alt="SSB Septic truck ready for service" class="image" />
                </div>
                <div class="feature-content">
                    <h2 class="feature-title">Ready to Book?</h2>
                    <p class="feature-text">Don't wait for septic problems to get worse. Schedule your professional septic service with SSB today and ensure your system runs smoothly year-round.</p>
                    <p class="feature-text"><strong>Call now for immediate assistance or to schedule your appointment at your convenience.</strong></p>
                    <a href="tel:+12068338777" class="feature-cta">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                        </svg>
                        <span>Call Us Now: (206) 833-8777</span>
                    </a>
                </div>
            </div>

            <!-- Learn More Section -->
            <div class="feature-card feature-card-reverse">
                <div class="feature-image">
                    <Image src={liveService} alt="SSB Septic team providing professional service" class="image" />
                </div>
                <div class="feature-content">
                    <h2 class="feature-title">Want to Learn More?</h2>
                    <p class="feature-text">Discover more about our comprehensive septic services, our commitment to environmental protection, and why we're the trusted choice for septic system care in the Kent and Seattle area.</p>
                    <p class="feature-text">Learn about our eco-friendly approach, advanced equipment, and decades of combined experience in septic system maintenance and repair.</p>
                    <div class="feature-buttons">
                        <a href="/about" class="btn btn-primary">About SSB Septic</a>
                        <a href="/services" class="btn btn-secondary">Our Services & Pricing</a>
                    </div>
                </div>
            </div>

            <!-- Why Choose Us Section -->
            <div class="trust-card">
                <h2 class="trust-title">Why Choose SSB Septic Services?</h2>
                <div class="trust-grid">
                    <div class="trust-item">
                        <div class="trust-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                <path d="M9 12l2 2 4-4"/>
                            </svg>
                        </div>
                        <h3 class="trust-item-title">Licensed & Insured</h3>
                        <p class="trust-item-text">Fully licensed, bonded, and insured for your peace of mind and protection.</p>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <h3 class="trust-item-title">24/7 Emergency Service</h3>
                        <p class="trust-item-text">Septic emergencies don't wait. Neither do we. Available around the clock.</p>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                                <path d="M7 12h10"/>
                                <path d="M12 7v10"/>
                            </svg>
                        </div>
                        <h3 class="trust-item-title">Eco-Friendly Approach</h3>
                        <p class="trust-item-text">Environmental protection is our priority with every service we provide.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
        const form = document.getElementById("ssb-contact-form");
        const statusEl = document.getElementById("form-status");

        if (form && statusEl) {
            const params = new URLSearchParams(window.location.search);
            const setHidden = (name, value) => {
                const input = form.querySelector(`input[name="${name}"]`);
                if (input) input.value = value || "";
            };

            setHidden("gclid", params.get("gclid"));
            setHidden("gbraid", params.get("gbraid"));
            setHidden("wbraid", params.get("wbraid"));
            setHidden("utm_source", params.get("utm_source"));
            setHidden("utm_medium", params.get("utm_medium"));
            setHidden("utm_campaign", params.get("utm_campaign"));
            setHidden("landing_page", window.location.href);
            setHidden("referrer", document.referrer || "");

            form.addEventListener("submit", async (event) => {
                event.preventDefault();
                statusEl.textContent = "";
                statusEl.classList.remove("error");

                const formData = new FormData(form);
                const services = formData.getAll("services").map((value) => String(value));

                if (services.length === 0) {
                    statusEl.textContent = "Please select at least one service.";
                    statusEl.classList.add("error");
                    return;
                }

                const payload = {
                    firstName: String(formData.get("firstName") || ""),
                    lastName: String(formData.get("lastName") || ""),
                    streetAddress: String(formData.get("streetAddress") || ""),
                    city: String(formData.get("city") || ""),
                    zip: String(formData.get("zip") || ""),
                    services,
                    website: String(formData.get("website") || ""),
                    gclid: String(formData.get("gclid") || ""),
                    gbraid: String(formData.get("gbraid") || ""),
                    wbraid: String(formData.get("wbraid") || ""),
                    utm_source: String(formData.get("utm_source") || ""),
                    utm_medium: String(formData.get("utm_medium") || ""),
                    utm_campaign: String(formData.get("utm_campaign") || ""),
                    landing_page: String(formData.get("landing_page") || ""),
                    referrer: String(formData.get("referrer") || ""),
                };

                const submitButton = form.querySelector('button[type="submit"]');
                if (submitButton) submitButton.disabled = true;

                try {
                    const response = await fetch("/api/contact", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload),
                    });
                    const result = await response.json();

                    if (!response.ok || !result.ok) {
                        const defaultError = "Unable to send request. Please call us at (206) 833-8777.";
                        const firstFieldError = result?.errors ? Object.values(result.errors)[0] : "";
                        statusEl.textContent = result.error || firstFieldError || defaultError;
                        statusEl.classList.add("error");
                        return;
                    }

                    statusEl.textContent = "Thanks, your request has been submitted.";
                    statusEl.classList.remove("error");
                    form.reset();
                    setHidden("landing_page", window.location.href);
                    setHidden("referrer", document.referrer || "");
                } catch (error) {
                    statusEl.textContent = "Unable to send request. Please call us at (206) 833-8777.";
                    statusEl.classList.add("error");
                } finally {
                    if (submitButton) submitButton.disabled = false;
                }
            });
        }
    </script>
</Layout>

<style>
/* Page Hero */
.page-hero {
    position: relative;
    padding: 8rem 1.25rem 5rem;
    text-align: center;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 50%, #1e3a5f 100%);
    z-index: -1;
}

.hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.hero-container {
    max-width: 48rem;
    margin: 0 auto;
}

.hero-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #86efc0;
    margin-bottom: 1rem;
}

.hero-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.1;
}

.hero-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
}

/* Section Container */
.section-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
}

/* Contact Section */
.contact-section {
    padding: 4rem 0 5rem;
    background: #f8fafc;
}

/* Info Card */
.info-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    margin-bottom: 2rem;
}

.info-header {
    text-align: center;
    margin-bottom: 2rem;
}

.info-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 1rem;
}

.info-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0;
    max-width: 48rem;
    margin: 0 auto;
}

.info-grid {
    display: grid;
    gap: 2rem;
}

.info-block {
    padding: 1.5rem;
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-radius: 16px;
    border: 1px solid #e2e8f0;
}

.info-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 12px;
    margin-bottom: 1rem;
}

.info-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.info-block-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 1rem;
}

.info-details p {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 0.5rem;
    line-height: 1.6;
}

.info-details p:last-child {
    margin-bottom: 0;
}

.info-details .highlight {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed #e2e8f0;
    color: #2d8a6e;
    font-weight: 500;
}

.info-link {
    color: #1e3a5f;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
}

.info-link:hover {
    color: #2d8a6e;
}

/* Form Card */
.form-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    margin-bottom: 2rem;
}

.form-header {
    margin-bottom: 1.5rem;
}

.form-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 0.5rem;
}

.form-text {
    margin: 0;
    color: #64748b;
    line-height: 1.6;
}

.lead-form {
    display: grid;
    gap: 1rem;
}

.form-grid {
    display: grid;
    gap: 1rem;
}

.form-field {
    display: grid;
    gap: 0.45rem;
    font-size: 0.92rem;
    color: #334155;
}

.form-field span {
    font-weight: 600;
}

.form-field input {
    width: 100%;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 0.75rem 0.85rem;
    font: inherit;
    color: #0f172a;
    background: #fff;
}

.form-field input:focus {
    border-color: #2d8a6e;
    outline: 2px solid rgba(45, 138, 110, 0.2);
    outline-offset: 0;
}

.services-fieldset {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1rem;
    margin: 0;
}

.services-fieldset legend {
    font-weight: 600;
    color: #1e3a5f;
    padding: 0 0.4rem;
}

.services-grid {
    display: grid;
    gap: 0.65rem;
}

.services-grid label {
    font-size: 0.94rem;
    color: #334155;
    display: flex;
    gap: 0.55rem;
    align-items: center;
}

.services-grid input {
    width: 1rem;
    height: 1rem;
}

.form-submit {
    border: 0;
    cursor: pointer;
    border-radius: 12px;
    padding: 0.95rem 1.2rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}

.form-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(30, 58, 95, 0.38);
}

.form-submit:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
}

.form-status {
    min-height: 1.4rem;
    margin: 0;
    font-weight: 600;
    color: #2d8a6e;
}

.form-status.error {
    color: #b91c1c;
}

.honeypot {
    position: absolute;
    left: -9999px;
}

/* Feature Card */
.feature-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
}

.feature-image {
    height: 280px;
    overflow: hidden;
}

.image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.feature-content {
    padding: 2rem;
    text-align: center;
}

.feature-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 1rem;
}

.feature-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0 0 1rem;
}

.feature-text:last-of-type {
    margin-bottom: 1.5rem;
}

.feature-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    color: white;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 12px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
}

.feature-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(30, 58, 95, 0.4);
}

.feature-cta svg {
    width: 1.25rem;
    height: 1.25rem;
}

.feature-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s ease;
}

.btn-primary {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(30, 58, 95, 0.4);
}

.btn-secondary {
    background: #f1f5f9;
    color: #1e3a5f;
    border: 1px solid #e2e8f0;
}

.btn-secondary:hover {
    background: #e2e8f0;
}

/* Trust Card */
.trust-card {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
}

.trust-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin: 0 0 2rem;
}

.trust-grid {
    display: grid;
    gap: 1.5rem;
}

.trust-item {
    text-align: center;
}

.trust-icon {
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(45, 138, 110, 0.2);
    border: 1px solid rgba(45, 138, 110, 0.3);
    border-radius: 50%;
    margin: 0 auto 1rem;
}

.trust-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: #4ade9d;
}

.trust-item-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.0625rem;
