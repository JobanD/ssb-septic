---
import { Image } from "astro:assets";
import logo from "../assets/official-logo-transparent.png"
---
<header id="nav" class="bg-white">
    <div class="container">
        <!--Nav Logo-->
        <a href="/" class="logo flex items-center no-underline text-current" aria-label="back to home">
          <!-- <p class="font-bold text-3xl md:text-6xl lg:text-7xl text-primary">SSB</p> -->
            <div class="h-12 md:h-32 lg:h-24" >
                <Image src={logo} alt="Septic Pump SSB Logo" densities={[1.5, 2]} class="w-full h-full m-0 p-0" />
            </div>
        </a>
        <div class="flex items-center space-x-1 text-xs sm:text-sm md:text-lg lg:text-2xl mt-0 mr-auto mb-0 ml-0">
          <a href="tel:+12068338777" class="bg-primary hover:bg-black text-white font-bold py-1 sm:py-2 px-2 sm:px-4 rounded-full shadow-lg hover:shadow-xl transition duration-300 ease-in-out">
              <span class="hidden sm:inline">Call Us:</span> +1 (206) 833-8777
          </a>
        </div>


        <!--Navigation List-->
        <nav class="nav" role="navigation">
            <!--Mobile Nav Toggle-->
            <button class="toggle" aria-label="mobile menu toggle">
                <div class="box" aria-hidden="true">
                    <span class="line line1" aria-hidden="true"></span>
                    <span class="line line2" aria-hidden="true"></span>
                    <span class="line line3" aria-hidden="true"></span>
                </div>
            </button>
            <!-- We need a wrapper div so we can set a fixed height on the ul in case the nav list gets too long from too many dropdowns being opened and needs to have an overflow scroll. This wrapper acts as the background so it can go the full height of the screen and not cut off any overflowing nav items while the ul stops short of the bottom of the screen, which keeps all nav items in view no matter how mnay there are-->
            <div class="ul-wrapper">
                <!-- Close button -->
                <button class="close-btn" aria-label="close menu">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <ul id="expanded" class="ul font-bold" aria-expanded="false">
                    <li class="li">
                      <a href="/" class="li-link active">
                          Home
                      </a>
                    </li>
                    <li class="li">
                        <a href="/about" class="li-link">
                            About
                        </a>
                    </li>
                    <li class="li">
                        <a href="/services" class="li-link">
                            Services
                        </a>
                    </li>
                    <li class="li">
                        <a href="/faq" class="li-link">
                            FAQ
                        </a>
                    </li>
                    <li class="li">
                        <a href="/contact" class="li-link special-link">
                            Contact Us
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>
</header>

<style>
    /* Mobile - 768px */
@media only screen and (max-width: 57.9375rem) {
  body.open {
    overflow: hidden;
  }
  #nav {
    width: 100%;
    box-sizing: border-box;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    position: sticky;
    top: 0;
    z-index: 10000;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav:before {
    content: "";
    width: 100%;
    height: 0vh;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    z-index: -1;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  #nav.active:before {
    height: 100vh;
    opacity: 1;
  }
  #nav.active .ul-wrapper {
    opacity: 1;
    transform: translateX(0);
    visibility: visible;
  }
  #nav.active .li {
    opacity: 1;
    transform: translateY(0);
  }
  #nav .container {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  #nav .logo {
    height: 3rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    z-index: 100;
  }
  #nav .logo img {
    width: auto;
    height: 100%;
    object-fit: contain;
  }
  #nav .toggle {
    width: 48px;
    height: 48px;
    background: hsl(217, 90%, 55%);
    border: none;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 12px rgba(55, 125, 255, 0.3);
    z-index: 100;
  }
  #nav .toggle:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(55, 125, 255, 0.4);
    background: hsl(217, 90%, 60%);
  }
  #nav .toggle:active {
    transform: translateY(0);
    transition: transform 0.1s;
  }
  #nav .box {
    width: 24px;
    height: 20px;
    position: relative;
  }
  #nav .line {
    width: 100%;
    height: 3px;
    background-color: white;
    border-radius: 2px;
    position: absolute;
    left: 0;
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }
  #nav .line1 {
    top: 0;
  }
  #nav .line2 {
    top: 50%;
    transform: translateY(-50%);
  }
  #nav .line3 {
    bottom: 0;
  }
  #nav .active .line1 {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  #nav .active .line2 {
    opacity: 0;
    transform: translateY(-50%) scale(0);
  }
  #nav .active .line3 {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }
  #nav .ul-wrapper {
    width: 280px;
    height: 100vh;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.95) 100%);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: -20px 0 40px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    position: fixed;
    top: 0;
    right: 0;
    z-index: 50;
    transform: translateX(100%);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav .close-btn {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: #666;
    z-index: 100;
  }
  #nav .close-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    transform: rotate(90deg);
  }
  #nav .close-btn:active {
    transform: rotate(90deg) scale(0.95);
  }
  #nav .ul {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 120px 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    gap: 8px;
    overflow-y: auto;
  }
  #nav .li {
    list-style: none;
    width: 100%;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav .li:nth-of-type(1) { transition-delay: 0.1s; }
  #nav .li:nth-of-type(2) { transition-delay: 0.15s; }
  #nav .li:nth-of-type(3) { transition-delay: 0.2s; }
  #nav .li:nth-of-type(4) { transition-delay: 0.25s; }
  #nav .li:nth-of-type(5) { transition-delay: 0.3s; }
  #nav .li-link {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: none;
    color: #2d3748;
    padding: 16px 20px;
    margin: 0;
    border-radius: 12px;
    display: block;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
  #nav .li-link:hover {
    background: rgba(55, 125, 255, 0.1);
    border-color: rgba(55, 125, 255, 0.2);
    transform: translateX(8px);
    color: hsl(217, 90%, 55%);
  }
  #nav .li-link.active {
    background: hsl(217, 90%, 55%);
    color: white;
    border-color: hsl(217, 90%, 55%);
    box-shadow: 0 4px 12px rgba(55, 125, 255, 0.3);
  }
  #nav .li-link.active:hover {
    background: hsl(217, 90%, 60%);
    transform: translateX(8px);
    color: white;
  }
  #nav .li-link.special-link {
    background: linear-gradient(135deg, hsl(217, 90%, 55%) 0%, hsl(217, 90%, 65%) 100%);
    color: white;
    border: none;
    box-shadow: 0 6px 20px rgba(55, 125, 255, 0.4);
    margin-top: 16px;
    text-align: center;
    font-weight: 700;
  }
  #nav .li-link.special-link:hover {
    background: linear-gradient(135deg, hsl(217, 90%, 45%) 0%, hsl(217, 90%, 55%) 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(55, 125, 255, 0.5);
    color: white;
  }
  #nav .button-solid {
    display: none;
  }
}
/*-- -------------------------- -->
<---     Desktop Navigation     -->
<--- -------------------------- -*/
/* Small Desktop - 768px */
@media only screen and (min-width: 58rem) {
  #nav {
    width: 100%;
    /* prevents padding and border from affecting height and width */
    box-sizing: border-box;
    padding: 0 1rem;
    box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
    position: sticky;
    top: 0;
    z-index: 10000;
  }
  #nav .container {
    width: 100%;
    max-width: 80rem;
    margin: auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }
  #nav .toggle {
    display: none;
  }
  #nav .logo {
    /* width: 18.4%;
    max-width: 21.875rem; */
    height: 4rem;
    /* margin-right auto pushes everything away from it to the right */
    margin: 0 auto 0 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
  }
  #nav .ul {
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    /* 20px - 36px */
    gap: clamp(1.25rem, 2.6vw, 2.25rem);
  }
  #nav .li {
    list-style: none;
    padding: 2.5rem 0;
    /* prevent flexbox from squishing it */
    flex: none;
  }
  #nav .li-link {
    /* 14px - 16px */
    font-size: clamp(1.15rem, 1.3vw, 1.4rem);
    line-height: 1.5em;
    text-decoration: none;
    margin: 0;
    color: var(--bodyTextColor);
    display: block;
    position: relative;
  }
  #nav .li-link:hover:before {
    width: 100%;
  }
  #nav .li-link.active:before {
    width: 100%;
  }
  #nav .li-link:before {
    /* active state underline */
    content: "";
    width: 0%;
    height: 2px;
    background: var(--primary);
    opacity: 1;
    display: block;
    position: absolute;
    bottom: 0rem;
    left: 0;
    transition: width 0.3s;
  }
  #nav .button-solid {
    font-size: 1rem;
    font-weight: 700;
    /* 46px - 56px */
    line-height: clamp(2.875em, 5.5vw, 3.5em);
    text-align: center;
    text-decoration: none;
    min-width: 9.375rem;
    margin: 0;
    /* prevents padding from adding to the width */
    box-sizing: border-box;
    padding: 0 1.5rem;
    color: #fff;
    background-color: var(--primary);
    border-radius: 0.25rem;
    display: inline-block;
    position: relative;
    z-index: 1;
  }
  #nav .button-solid:before {
    content: "";
    width: 0%;
    height: 100%;
    background: #000;
    opacity: 1;
    border-radius: 0.25rem;
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
    transition: width 0.3s;
  }
  #nav .button-solid:hover:before {
    width: 100%;
  }

  .special-link {
    background-color: hsl(217, 90%, 55%);
    color: white !important;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    transition: background-color 0.3s ease;
  }

  .special-link:hover {
    background-color: hsl(218, 100%, 2%);
  }
}
</style>


<script>
  document.addEventListener('DOMContentLoaded', function() {
      const CSbody = document.querySelector('body');
      const CSnavbarMenu = document.querySelector('#nav');
      const toggle = document.querySelector('.toggle');
      const closeBtn = document.querySelector('.close-btn');
      const ulWrapper = document.querySelector('.ul-wrapper');

      if (!CSbody || !CSnavbarMenu) return;

      function closeMenu() {
          toggle?.classList.remove('active');
          CSnavbarMenu.classList.remove('active');
          CSbody.classList.remove('open');
          ariaExpanded();
      }

      function openMenu() {
          toggle?.classList.add('active');
          CSnavbarMenu.classList.add('active');
          CSbody.classList.add('open');
          ariaExpanded();
      }

      function toggleMenu() {
          if (CSnavbarMenu.classList.contains('active')) {
              closeMenu();
          } else {
              openMenu();
          }
      }

      // Toggle button click
      toggle?.addEventListener('click', function(e) {
          e.stopPropagation();
          toggleMenu();
      });

      // Close button click
      closeBtn?.addEventListener('click', function(e) {
          e.stopPropagation();
          closeMenu();
      });

      // Click outside to close
      document.addEventListener('click', function(event) {
          if (!CSnavbarMenu.classList.contains('active')) return;

          // Don't close if clicking inside the menu
          if (ulWrapper?.contains(event.target) || toggle?.contains(event.target)) {
              return;
          }

          closeMenu();
      });

      // Close on escape key
      document.addEventListener('keydown', function(event) {
          if (event.key === 'Escape' && CSnavbarMenu.classList.contains('active')) {
              closeMenu();
          }
      });

      // Close menu when clicking on nav links (mobile)
      const navLinks = document.querySelectorAll('.li-link');
      navLinks.forEach(link => {
          link.addEventListener('click', function() {
              if (window.innerWidth <= 928) { // Mobile breakpoint
                  setTimeout(closeMenu, 150); // Small delay for better UX
              }
          });
      });

      function ariaExpanded() {
          const csUL = document.querySelector('#expanded');
          if (!csUL) return;

          const csExpanded = csUL.getAttribute('aria-expanded');
          csUL.setAttribute('aria-expanded', csExpanded === 'false' ? 'true' : 'false');
      }

      activateCurrentLink();

      function activateCurrentLink() {
          const navLinks = document.querySelectorAll('#nav .li-link');
          const currentPath = window.location.pathname;

          navLinks.forEach(link => {
              if (link.getAttribute('href') === currentPath) {
                  link.classList.add('active');
              } else {
                  link.classList.remove('active');
              }
          });
      }
  });
</script>
