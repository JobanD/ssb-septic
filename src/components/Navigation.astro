---
import { Image } from "astro:assets";
import logo from "../assets/official-logo-transparent.png"
---
<header id="nav" class="bg-white/95 backdrop-blur-lg border-b border-slate-100">
    <div class="nav-container">
        <!--Nav Logo-->
        <a href="/" class="logo" aria-label="back to home">
            <div class="logo-wrapper">
                <Image src={logo} alt="SSB Septic Logo" densities={[1.5, 2]} class="logo-img" />
            </div>
        </a>

        <!-- Phone CTA (visible on all screens) -->
        <a href="tel:+12068338777" class="phone-cta">
            <svg class="phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="phone-text">(206) 833-8777</span>
        </a>

        <!--Navigation List-->
        <nav class="nav" role="navigation">
            <!--Mobile Nav Toggle-->
            <button class="toggle" aria-label="mobile menu toggle">
                <div class="hamburger" aria-hidden="true">
                    <span class="bar bar-1"></span>
                    <span class="bar bar-2"></span>
                    <span class="bar bar-3"></span>
                </div>
            </button>

            <div class="nav-overlay"></div>

            <div class="nav-drawer">
                <button class="close-btn" aria-label="close menu">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                </button>

                <ul id="expanded" class="nav-list" aria-expanded="false">
                    <li class="nav-item">
                        <a href="/" class="nav-link">Home</a>
                    </li>
                    <li class="nav-item">
                        <a href="/about" class="nav-link">About</a>
                    </li>
                    <li class="nav-item">
                        <a href="/services" class="nav-link">Services</a>
                    </li>
                    <li class="nav-item">
                        <a href="/faq" class="nav-link">FAQ</a>
                    </li>
                    <li class="nav-item">
                        <a href="/contact" class="nav-link nav-cta">Contact Us</a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>
</header>

<style>
/* ============================================
   Base Header Styles
   ============================================ */
#nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: all 0.3s ease;
}

#nav.scrolled {
    box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.1);
}

.nav-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
}

/* ============================================
   Logo
   ============================================ */
.logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    z-index: 100;
}

.logo-wrapper {
    height: 3rem;
}

.logo-img {
    height: 100%;
    width: auto;
    object-fit: contain;
}

/* ============================================
   Phone CTA
   ============================================ */
.phone-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    border-radius: 9999px;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(30, 58, 95, 0.25);
}

.phone-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.35);
    background: linear-gradient(135deg, #2d5a8a 0%, #3d72a8 100%);
}

.phone-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
}

.phone-text {
    display: none;
}

/* ============================================
   Mobile Navigation (< 928px)
   ============================================ */
@media (max-width: 57.9375rem) {
    body.menu-open {
        overflow: hidden;
    }

    .nav-container {
        padding: 0.75rem 1rem;
    }

    .toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        background: #1e3a5f;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        z-index: 100;
        transition: all 0.3s ease;
    }

    .toggle:hover {
        background: #2d5a8a;
    }

    .hamburger {
        width: 20px;
        height: 14px;
        position: relative;
    }

    .bar {
        position: absolute;
        left: 0;
        width: 100%;
        height: 2px;
        background: white;
        border-radius: 2px;
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .bar-1 { top: 0; }
    .bar-2 { top: 50%; transform: translateY(-50%); }
    .bar-3 { bottom: 0; }

    #nav.active .bar-1 {
        top: 50%;
        transform: translateY(-50%) rotate(45deg);
    }

    #nav.active .bar-2 {
        opacity: 0;
        transform: translateY(-50%) scaleX(0);
    }

    #nav.active .bar-3 {
        bottom: 50%;
        transform: translateY(50%) rotate(-45deg);
    }

    .nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        backdrop-filter: blur(4px);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 40;
    }

    #nav.active .nav-overlay {
        opacity: 1;
        visibility: visible;
    }

    .nav-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(320px, 85vw);
        height: 100vh;
        background: white;
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 50;
        overflow-y: auto;
        box-shadow: -10px 0 40px rgba(0, 0, 0, 0.15);
    }

    #nav.active .nav-drawer {
        transform: translateX(0);
    }

    .close-btn {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        color: #475569;
    }

    .close-btn:hover {
        background: #fee2e2;
        color: #dc2626;
        transform: rotate(90deg);
    }

    .close-btn svg {
        width: 20px;
        height: 20px;
    }

    .nav-list {
        list-style: none;
        margin: 0;
        padding: 5rem 1.5rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .nav-item {
        opacity: 0;
        transform: translateX(20px);
        transition: all 0.4s ease;
    }

    #nav.active .nav-item {
        opacity: 1;
        transform: translateX(0);
    }

    #nav.active .nav-item:nth-child(1) { transition-delay: 0.1s; }
    #nav.active .nav-item:nth-child(2) { transition-delay: 0.15s; }
    #nav.active .nav-item:nth-child(3) { transition-delay: 0.2s; }
    #nav.active .nav-item:nth-child(4) { transition-delay: 0.25s; }
    #nav.active .nav-item:nth-child(5) { transition-delay: 0.3s; }

    .nav-link {
        display: block;
        padding: 1rem 1.25rem;
        font-size: 1.0625rem;
        font-weight: 500;
        color: #334155;
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.2s ease;
        background: #f8fafc;
    }

    .nav-link:hover,
    .nav-link.active {
        background: #1e3a5f;
        color: white;
    }

    .nav-link.nav-cta {
        margin-top: 1rem;
        background: linear-gradient(135deg, #2d8a6e 0%, #3daa8e 100%);
        color: white;
        text-align: center;
        font-weight: 600;
    }

    .nav-link.nav-cta:hover {
        background: linear-gradient(135deg, #1d7a5e 0%, #2d8a6e 100%);
    }
}

/* ============================================
   Desktop Navigation (>= 928px)
   ============================================ */
@media (min-width: 58rem) {
    .nav-container {
        padding: 0 2rem;
    }

    .logo-wrapper {
        height: 4rem;
    }

    .phone-text {
        display: block;
    }

    .phone-cta {
        order: 3;
        padding: 0.75rem 1.5rem;
        font-size: 0.9375rem;
    }

    .toggle,
    .close-btn,
    .nav-overlay {
        display: none;
    }

    .nav-drawer {
        position: static;
        width: auto;
        height: auto;
        background: transparent;
        transform: none;
        box-shadow: none;
        overflow: visible;
    }

    .nav-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .nav-item {
        opacity: 1;
        transform: none;
    }

    .nav-link {
        display: block;
        padding: 0.75rem 1rem;
        font-size: 0.9375rem;
        font-weight: 500;
        color: #475569;
        text-decoration: none;
        border-radius: 8px;
        position: relative;
        transition: all 0.2s ease;
    }

    .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0.5rem;
        left: 1rem;
        right: 1rem;
        height: 2px;
        background: #1e3a5f;
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.3s ease;
        border-radius: 1px;
    }

    .nav-link:hover {
        color: #1e3a5f;
    }

    .nav-link:hover::after,
    .nav-link.active::after {
        transform: scaleX(1);
    }

    .nav-link.active {
        color: #1e3a5f;
        font-weight: 600;
    }

    .nav-link.nav-cta {
        margin-left: 0.5rem;
        padding: 0.625rem 1.25rem;
        background: #1e3a5f;
        color: white;
        border-radius: 8px;
        font-weight: 600;
    }

    .nav-link.nav-cta::after {
        display: none;
    }

    .nav-link.nav-cta:hover {
        background: #2d5a8a;
        color: white;
    }
}

/* Large screens */
@media (min-width: 80rem) {
    .nav-list {
        gap: 0.5rem;
    }

    .nav-link {
        padding: 0.75rem 1.25rem;
        font-size: 1rem;
    }
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    var body = document.body;
    var nav = document.getElementById('nav');
    var toggle = document.querySelector('.toggle');
    var closeBtn = document.querySelector('.close-btn');
    var overlay = document.querySelector('.nav-overlay');

    if (!nav) return;

    function closeMenu() {
        if (nav) nav.classList.remove('active');
        body.classList.remove('menu-open');
        updateAriaExpanded(false);
    }

    function openMenu() {
        if (nav) nav.classList.add('active');
        body.classList.add('menu-open');
        updateAriaExpanded(true);
    }

    function toggleMenu() {
        if (nav) {
            nav.classList.contains('active') ? closeMenu() : openMenu();
        }
    }

    function updateAriaExpanded(expanded) {
        var ul = document.getElementById('expanded');
        if (ul) ul.setAttribute('aria-expanded', String(expanded));
    }

    // Event listeners
    if (toggle) {
        toggle.addEventListener('click', function(e) {
            e.stopPropagation();
            toggleMenu();
        });
    }

    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    if (overlay) overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && nav && nav.classList.contains('active')) {
            closeMenu();
        }
    });

    // Close menu on nav link click (mobile)
    document.querySelectorAll('.nav-link').forEach(function(link) {
        link.addEventListener('click', function() {
            if (window.innerWidth <= 928) {
                setTimeout(closeMenu, 100);
            }
        });
    });

    // Set active link based on current path
    var currentPath = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(function(link) {
        var href = link.getAttribute('href');
        if (href === currentPath || (currentPath === '/' && href === '/')) {
            link.classList.add('active');
        }
    });

    // Header scroll effect
    window.addEventListener('scroll', function() {
        var currentScroll = window.scrollY || document.documentElement.scrollTop;
        if (nav) {
            if (currentScroll > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        }
    }, { passive: true });
});
</script>
