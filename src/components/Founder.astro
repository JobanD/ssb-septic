---
import { Image } from "astro:assets";
import truckInLot from "../assets/truck-in-lot.jpg"
---

<section class="founder-section">
    <div class="founder-container">
        <div class="founder-content">
            <span class="founder-label">Our Commitment</span>
            <h2 class="founder-title">Leading the Industry</h2>
            <p class="founder-subtitle">Dedicated to Excellence in Septic Services</p>
        </div>

        <div class="founder-card">
            <div class="founder-image-wrapper">
                <Image
                    src={truckInLot}
                    alt="SSB Septic service truck in lot"
                    class="founder-image"
                    widths={[400, 600, 800]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                />
                <div class="image-overlay"></div>
            </div>
            <div class="founder-text">
                <h3 class="founder-text-title">Pioneering Excellence</h3>
                <p class="founder-text-content">
                    At SSB, we are dedicated to pioneering innovative and environmentally friendly septic solutions. With over two decades of leading the industry,
                    our commitment to excellence and sustainability has set us apart as a trusted name in septic services.
                </p>
                <p class="founder-text-content">
                    We continuously strive to improve our techniques and technologies to ensure high-quality, reliable outcomes for all our clients.
                </p>
                <a href="/about" class="founder-cta">
                    <span>Learn More About Us</span>
                    <svg viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>

<style>
.founder-section {
    padding: 5rem 1.25rem;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 50%, #1e3a5f 100%);
    position: relative;
    overflow: hidden;
}

.founder-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
}

.founder-container {
    max-width: 72rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.founder-content {
    text-align: center;
    margin-bottom: 3rem;
}

.founder-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #86efc0;
    margin-bottom: 0.75rem;
}

.founder-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: white;
    margin: 0 0 0.75rem;
    line-height: 1.1;
}

.founder-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
}

.founder-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    display: flex;
    flex-direction: column;
}

.founder-image-wrapper {
    position: relative;
    height: 280px;
    overflow: hidden;
}

.founder-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.founder-card:hover .founder-image {
    transform: scale(1.05);
}

.image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.1) 100%);
    pointer-events: none;
}

.founder-text {
    padding: 2rem;
}

.founder-text-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 1rem;
}

.founder-text-content {
    font-size: 1rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0 0 1rem;
}

.founder-text-content:last-of-type {
    margin-bottom: 1.5rem;
}

.founder-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, #2d8a6e 0%, #3daa8e 100%);
    color: white;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(45, 138, 110, 0.3);
}

.founder-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(45, 138, 110, 0.4);
}

.founder-cta svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.3s ease;
}

.founder-cta:hover svg {
    transform: translateX(4px);
}

/* Tablet & Desktop */
@media (min-width: 768px) {
    .founder-section {
        padding: 6rem 2rem;
    }

    .founder-card {
        flex-direction: row;
        align-items: stretch;
    }

    .founder-image-wrapper {
        width: 45%;
        height: auto;
        min-height: 400px;
    }

    .founder-text {
        width: 55%;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .founder-text-title {
        font-size: 1.75rem;
    }

    .founder-text-content {
        font-size: 1.0625rem;
    }
}

@media (min-width: 1024px) {
    .founder-section {
        padding: 7rem 2rem;
    }

    .founder-content {
        margin-bottom: 4rem;
    }

    .founder-image-wrapper {
        width: 50%;
    }

    .founder-text {
        width: 50%;
        padding: 3.5rem;
    }

    .founder-text-title {
        font-size: 2rem;
    }
}
</style>
