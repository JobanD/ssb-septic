---
import Card from "../components/Card.astro";

// Update or refine these props as needed
const services = [
  {
    title: "Our Pricing",
    description: "Transparent, competitive pricing for all septic services. No hidden fees, just honest quotes for pumping, maintenance, repairs, and installations throughout Kent and Seattle.",
    href: "/services",
  },
  {
    title: "Learn More About Us",
    description: "Discover our family-owned business story, environmental commitment, and why we're Kent's trusted septic experts with over a decade of reliable service and 100% customer satisfaction.",
    href: "/about",
  },
  {
    title: "FAQ",
    description: "Get expert answers to your septic questions. Learn about maintenance schedules, warning signs, emergency services, and how to keep your septic system running smoothly year-round.",
    href: "/faq",
  },
];
---
    <!-- Introduction Section -->
    <section class="bg-gray-50 py-16">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-4xl font-bold text-gray-900 mb-6">Kent's Premier Septic Service Company</h2>
            <p class="text-xl text-gray-700 mb-8 max-w-4xl mx-auto">
                For over a decade, SSB Septic Services has been the trusted choice for residential and commercial septic system care throughout the Kent and Seattle area.
                Our licensed, experienced team provides comprehensive septic solutions with an unwavering commitment to environmental protection and customer satisfaction.
            </p>
            <div class="grid md:grid-cols-3 gap-8 mt-12">
                <div class="bg-white p-6 rounded-lg shadow-md">
                    <div class="text-primary text-3xl font-bold mb-2">24/7</div>
                    <h3 class="text-xl font-semibold mb-2">Emergency Service</h3>
                    <p class="text-gray-600">Septic emergencies don't wait. Our rapid response team is available around the clock to handle urgent repairs and system failures.</p>
                </div>
                <div class="bg-white p-6 rounded-lg shadow-md">
                    <div class="text-primary text-3xl font-bold mb-2">10+</div>
                    <h3 class="text-xl font-semibold mb-2">Years Experience</h3>
                    <p class="text-gray-600">Decades of combined experience in septic system installation, maintenance, repair, and environmental compliance throughout Western Washington.</p>
                </div>
                <div class="bg-white p-6 rounded-lg shadow-md">
                    <div class="text-primary text-3xl font-bold mb-2">100%</div>
                    <h3 class="text-xl font-semibold mb-2">Success Rate</h3>
                    <p class="text-gray-600">Our track record speaks for itself. Every septic system we service functions flawlessly, ensuring long-term reliability and customer satisfaction.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Overview -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">Comprehensive Septic Solutions</h2>
            <p class="text-lg text-gray-700 max-w-3xl mx-auto">
                From routine maintenance to emergency repairs, we offer complete septic services designed to keep your system running efficiently
                while protecting your property and the environment.
            </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
            {services.map((service) => (
                <Card title={service.title} body={service.description} href={service.href}>
                    <h2 class="text-2xl font-bold text-gray-800 mb-1 md:mb-3">{service.title}<span class="text-primary-500 ml-2">&rarr;</span></h2>
                    <p>{service.description}</p>
                </Card>
            ))}
        </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="bg-primary py-16 text-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold mb-4">Why Kent Residents Trust SSB Septic</h2>
                <p class="text-xl opacity-90 max-w-3xl mx-auto">
                    Our commitment to excellence, environmental responsibility, and customer satisfaction sets us apart as the leading septic service provider in the region.
                </p>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="text-center">
                    <div class="bg-white bg-opacity-20 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Licensed & Insured</h3>
                    <p class="text-sm opacity-90">Fully licensed, bonded, and insured for complete protection and peace of mind.</p>
                </div>
                <div class="text-center">
                    <div class="bg-white bg-opacity-20 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Rapid Response</h3>
                    <p class="text-sm opacity-90">Emergency services available 24/7 with our experienced rapid response team.</p>
                </div>
                <div class="text-center">
                    <div class="bg-white bg-opacity-20 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Eco-Friendly</h3>
                    <p class="text-sm opacity-90">Environmental protection is our priority with every service we provide.</p>
                </div>
                <div class="text-center">
                    <div class="bg-white bg-opacity-20 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Local Experts</h3>
                    <p class="text-sm opacity-90">Family-owned business with deep roots and commitment to our Kent community.</p>
                </div>
            </div>
        </div>
    </section>
