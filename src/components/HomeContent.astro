---
const services = [
  {
    title: "Our Pricing",
    description: "Transparent, competitive pricing for all septic services. No hidden fees, just honest quotes for pumping, maintenance, repairs, and installations throughout Kent and Seattle.",
    href: "/services",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: "Learn More About Us",
    description: "Discover our family-owned business story, environmental commitment, and why we're Kent's trusted septic experts with over a decade of reliable service and 100% customer satisfaction.",
    href: "/about",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: "FAQ",
    description: "Get expert answers to your septic questions. Learn about maintenance schedules, warning signs, emergency services, and how to keep your septic system running smoothly year-round.",
    href: "/faq",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  },
];
---

<!-- Introduction Section -->
<section class="intro-section">
    <div class="section-container">
        <div class="section-header">
            <span class="section-label">Trusted Local Experts</span>
            <h2 class="section-title">Kent's Premier Septic Service Company</h2>
            <p class="section-description">
                For over a decade, SSB Septic Services has been the trusted choice for residential and commercial septic system care throughout the Kent and Seattle area.
                Our licensed, experienced team provides comprehensive septic solutions with an unwavering commitment to environmental protection and customer satisfaction.
            </p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-number">24/7</span>
                    <h3 class="stat-title">Emergency Service</h3>
                    <p class="stat-text">Septic emergencies don't wait. Our rapid response team is available around the clock to handle urgent repairs and system failures.</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-number">10+</span>
                    <h3 class="stat-title">Years Experience</h3>
                    <p class="stat-text">Decades of combined experience in septic system installation, maintenance, repair, and environmental compliance throughout Western Washington.</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <span class="stat-number">100%</span>
                    <h3 class="stat-title">Success Rate</h3>
                    <p class="stat-text">Our track record speaks for itself. Every septic system we service functions flawlessly, ensuring long-term reliability and customer satisfaction.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Overview -->
<section class="services-section">
    <div class="section-container">
        <div class="section-header">
            <span class="section-label">What We Offer</span>
            <h2 class="section-title">Comprehensive Septic Solutions</h2>
            <p class="section-description">
                From routine maintenance to emergency repairs, we offer complete septic services designed to keep your system running efficiently
                while protecting your property and the environment.
            </p>
        </div>

        <div class="services-grid">
            {services.map((service) => (
                <a href={service.href} class="service-card">
                    <div class="service-icon" set:html={service.icon} />
                    <h3 class="service-title">{service.title}</h3>
                    <p class="service-description">{service.description}</p>
                    <span class="service-link">
                        Learn more
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                    </span>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="trust-section">
    <div class="section-container">
        <div class="trust-content">
            <span class="section-label section-label-light">Why Choose Us</span>
            <h2 class="trust-title">Why Kent Residents Trust SSB Septic</h2>
            <p class="trust-description">
                Our commitment to excellence, environmental responsibility, and customer satisfaction sets us apart as the leading septic service provider in the region.
            </p>
        </div>

        <div class="trust-grid">
            <div class="trust-card">
                <div class="trust-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <path d="M9 12l2 2 4-4"/>
                    </svg>
                </div>
                <h3 class="trust-card-title">Licensed & Insured</h3>
                <p class="trust-card-text">Fully licensed, bonded, and insured for complete protection and peace of mind.</p>
            </div>

            <div class="trust-card">
                <div class="trust-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <h3 class="trust-card-title">Rapid Response</h3>
                <p class="trust-card-text">Emergency services available 24/7 with our experienced rapid response team.</p>
            </div>

            <div class="trust-card">
                <div class="trust-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                        <path d="M7 12h10"/>
                        <path d="M12 7v10"/>
                    </svg>
                </div>
                <h3 class="trust-card-title">Eco-Friendly</h3>
                <p class="trust-card-text">Environmental protection is our priority with every service we provide.</p>
            </div>

            <div class="trust-card">
                <div class="trust-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <h3 class="trust-card-title">Local Experts</h3>
                <p class="trust-card-text">Family-owned business with deep roots and commitment to our Kent community.</p>
            </div>
        </div>
    </div>
</section>

<style>
/* Section Container */
.section-container {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 1.25rem;
}

/* Section Header */
.section-header {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem;
}

.section-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2d8a6e;
    margin-bottom: 0.75rem;
}

.section-label-light {
    color: #86efc0;
}

.section-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1rem;
    line-height: 1.2;
}

.section-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0;
}

/* Intro Section */
.intro-section {
    padding: 5rem 0;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    gap: 1.5rem;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
}

.stat-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 12px;
}

.stat-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #2d8a6e;
    line-height: 1;
    display: block;
    margin-bottom: 0.5rem;
}

.stat-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.5rem;
}

.stat-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
}

/* Services Section */
.services-section {
    padding: 5rem 0;
    background: white;
}

.services-grid {
    display: grid;
    gap: 1.5rem;
}

.service-card {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
}

.service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    border-color: #1e3a5f;
}

.service-card:hover .service-link {
    color: #1e3a5f;
}

.service-card:hover .service-link svg {
    transform: translateX(4px);
}

.service-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 12px;
    margin-bottom: 1.25rem;
}

.service-icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.service-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.75rem;
}

.service-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0 0 1.5rem;
    flex: 1;
}

.service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #2d8a6e;
    transition: color 0.2s ease;
}

.service-link svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
}

/* Trust Section */
.trust-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
}

.trust-content {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem;
}

.trust-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.2;
}

.trust-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
}

.trust-grid {
    display: grid;
    gap: 1.5rem;
}

.trust-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    transition: all 0.3s ease;
}

.trust-card:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
}

.trust-icon {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(45, 138, 110, 0.2);
    border: 1px solid rgba(45, 138, 110, 0.3);
    border-radius: 50%;
    margin: 0 auto 1.25rem;
}

.trust-icon svg {
    width: 1.75rem;
    height: 1.75rem;
    color: #4ade9d;
}

.trust-card-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
}

.trust-card-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
}

/* Responsive */
@media (min-width: 640px) {
    .section-container {
        padding: 0 2rem;
    }

    .stats-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .stat-card {
        text-align: center;
        align-items: center;
    }

    .services-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .trust-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 1024px) {
    .intro-section,
    .services-section,
    .trust-section {
        padding: 6rem 0;
    }

    .section-header {
        margin-bottom: 4rem;
    }

    .trust-grid {
        grid-template-columns: repeat(4, 1fr);
    }
}
</style>
