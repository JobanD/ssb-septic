---
import { Image } from "astro:assets";
import truckHero from "../assets/truck-right-mountains.jpg"
---

<section class="hero">
    <!-- Background -->
    <div class="hero-bg">
        <Image
            src={truckHero}
            alt="SSB Septic truck with mountain backdrop"
            class="hero-bg-img"
            loading="eager"
            widths={[640, 960, 1280, 1920]}
            sizes="100vw"
        />
        <div class="hero-overlay"></div>
        <!-- Decorative gradient accent -->
        <div class="hero-accent"></div>
    </div>

    <div class="hero-container">
        <div class="hero-content">
            <!-- Badge -->
            <div class="hero-badge">
                <svg class="badge-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>Trusted by Kent & Seattle homeowners</span>
            </div>

            <!-- Main heading -->
            <h1 class="hero-title">
                Get All Your Septic Needs Covered
                <span class="title-accent">Quickly & Efficiently</span>
            </h1>

            <!-- Subtext -->
            <p class="hero-text">
                Professional septic services with over a decade of experience. 24/7 emergency response, eco-friendly solutions, and 100% customer satisfaction guaranteed.
            </p>

            <!-- CTA Buttons -->
            <div class="hero-cta">
                <a href="/services" class="btn btn-primary">
                    <span>View Services & Pricing</span>
                    <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                </a>
                <a href="tel:+12068338777" class="btn btn-secondary">
                    <svg class="btn-icon-left" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                    </svg>
                    <span>Call (206) 833-8777</span>
                </a>
            </div>
        </div>

        <!-- Feature Cards -->
        <div class="hero-cards">
            <div class="feature-card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <h3 class="card-title">100% Success Rate</h3>
                <p class="card-text">
                    Our track record is impeccable: every septic system we've worked on functions flawlessly, ensuring long-term satisfaction.
                </p>
            </div>

            <div class="feature-card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <h3 class="card-title">Rapid Response Team</h3>
                <p class="card-text">
                    Emergencies can't wait, which is why our rapid response team is ready to tackle your septic needs promptly and efficiently.
                </p>
            </div>

            <div class="feature-card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
                    </svg>
                </div>
                <h3 class="card-title">Customer Satisfaction</h3>
                <p class="card-text">
                    With a focus on customer satisfaction, we're proud that homeowners and businesses highly recommend our services.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
.hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 6rem 1.25rem 3rem;
    overflow: hidden;
}

/* Background */
.hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
}

.hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        135deg,
        rgba(15, 23, 42, 0.92) 0%,
        rgba(30, 58, 95, 0.85) 50%,
        rgba(15, 23, 42, 0.75) 100%
    );
}

.hero-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(
        to top,
        rgba(45, 138, 110, 0.15) 0%,
        transparent 100%
    );
    pointer-events: none;
}

/* Container */
.hero-container {
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
}

/* Content */
.hero-content {
    max-width: 42rem;
}

/* Badge */
.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(45, 138, 110, 0.2);
    border: 1px solid rgba(45, 138, 110, 0.3);
    border-radius: 9999px;
    color: #86efc0;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: fadeInDown 0.6s ease-out forwards;
}

.badge-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
}

/* Title */
.hero-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: white;
    margin: 0 0 1.5rem;
    animation: fadeInUp 0.6s ease-out 0.1s forwards;
    opacity: 0;
}

.title-accent {
    display: block;
    background: linear-gradient(135deg, #86efc0 0%, #4ade9d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Text */
.hero-text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 2rem;
    max-width: 36rem;
    animation: fadeInUp 0.6s ease-out 0.2s forwards;
    opacity: 0;
}

/* CTA Buttons */
.hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
    opacity: 0;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s ease;
    cursor: pointer;
}

.btn-primary {
    background: linear-gradient(135deg, #2d8a6e 0%, #3daa8e 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(45, 138, 110, 0.4);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(45, 138, 110, 0.5);
}

.btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
}

.btn-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.3s ease;
}

.btn-icon-left {
    width: 1rem;
    height: 1rem;
}

.btn-primary:hover .btn-icon {
    transform: translateX(4px);
}

/* Feature Cards */
.hero-cards {
    display: grid;
    gap: 1rem;
    animation: fadeInUp 0.6s ease-out 0.4s forwards;
    opacity: 0;
}

.feature-card {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
}

.feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
}

.card-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8a 100%);
    border-radius: 12px;
    margin-bottom: 1rem;
}

.card-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: white;
}

.card-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e3a5f;
    margin: 0 0 0.5rem;
}

.card-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
}

/* Animations */
@keyframes fadeInDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Tablet */
@media (min-width: 640px) {
    .hero {
        padding: 8rem 2rem 4rem;
    }

    .hero-cards {
        grid-template-columns: repeat(3, 1fr);
    }

    .btn {
        padding: 1rem 1.75rem;
    }
}

/* Desktop */
@media (min-width: 1024px) {
    .hero {
        padding: 0 2rem;
        min-height: 100vh;
    }

    .hero-container {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
        padding: 6rem 0;
    }

    .hero-content {
        flex: 1;
        max-width: 36rem;
    }

    .hero-title {
        font-size: 3.25rem;
    }

    .hero-text {
        font-size: 1.125rem;
    }

    .hero-cards {
        flex: 0 0 auto;
        width: 340px;
        grid-template-columns: 1fr;
        gap: 1.25rem;
    }

    .feature-card {
        padding: 1.75rem;
    }

    .hero-overlay {
        background: linear-gradient(
            90deg,
            rgba(15, 23, 42, 0.95) 0%,
            rgba(30, 58, 95, 0.85) 40%,
            rgba(15, 23, 42, 0.7) 100%
        );
    }
}

/* Large Desktop */
@media (min-width: 1280px) {
    .hero-content {
        max-width: 42rem;
    }

    .hero-title {
        font-size: 3.75rem;
    }

    .hero-cards {
        width: 380px;
    }
}
</style>
