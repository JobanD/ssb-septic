---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
import Navigation from "@/components/Navigation.astro"
import Footer from "@/components/Footer.astro"
import MetaTags from '@/components/MetaTags.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- Preload fonts for performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">

		<MetaTags
			title={title}
			description={description}
			keywords="septic services, septic system repair, septic maintenance, eco-friendly septic solutions, septic tank installation, septic system experts, Seattle septic service, Kent septic service, residential septic services, commercial septic services"
			url="https://ssbseptic.com"
			image="https://ssbseptic.com/_astro/official-logo-transparent.C-WHKZP2_ZEKIeJ.webp"
		/>
		<title>{title}</title>
		<script is:inline type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "LocalBusiness",
            "name": "SSB Septic Services",
            "url": "https://ssbseptic.com",
            "telephone": "+1-206-833-8777",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "25000 180th Ave SE",
              "addressLocality": "Covington",
              "addressRegion": "WA",
              "postalCode": "98042",
              "addressCountry": "US"
            },
            "areaServed": {
              "@type": "Place",
              "name": "Kent and Seattle"
            },
            "description": "Professional septic system installation, pumping, and maintenance services.",
            "image": "https://ssbseptic.com/_astro/official-logo-transparent.C-WHKZP2_ZEKIeJ.webp"
          }
        </script>
	</head>
	<body class="font-sans antialiased text-slate-700 bg-warm-50">
		<Navigation />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--primary: #1e3a5f;
		--primary-light: #3d72a8;
		--accent: #2d8a6e;
		--accent-light: #4ade9d;
	}

	html {
		font-family: 'DM Sans', system-ui, sans-serif;
		scroll-behavior: smooth;
	}

	/* Smooth page transitions */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation-duration: 0.3s;
	}

	/* Selection styling */
	::selection {
		background-color: rgba(30, 58, 95, 0.2);
		color: #1e3a5f;
	}

	/* Focus styling for accessibility */
	:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
	}

	/* Improve text rendering */
	body {
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	/* Animation utilities */
	.animate-on-scroll {
		opacity: 0;
		transform: translateY(20px);
		transition: opacity 0.6s ease-out, transform 0.6s ease-out;
	}

	.animate-on-scroll.visible {
		opacity: 1;
		transform: translateY(0);
	}

	/* Stagger animations */
	.stagger-1 { animation-delay: 0.1s; }
	.stagger-2 { animation-delay: 0.2s; }
	.stagger-3 { animation-delay: 0.3s; }
	.stagger-4 { animation-delay: 0.4s; }
	.stagger-5 { animation-delay: 0.5s; }
</style>
